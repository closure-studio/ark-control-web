{
  "name": "ark-control-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check:ai": "node --test scripts/check-ai-code.test.mjs && node scripts/check-ai-code.mjs",
    "check:dead-code": "knip --no-progress",
    "check:duplicates": "jscpd --config .jscpd.json --no-tips src",
    "ci": "npm run typecheck && npm run quality && npm test && npm run build",
    "deploy": "npm run build && wrangler deploy",
    "dev": "vite",
    "dev:worker": "npm run build && wrangler dev",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "quality": "npm run lint && npm run check:ai && npm run check:dead-code && npm run check:duplicates",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "daisyui": "^5.5.23",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jscpd": "^5.0.12",
    "jsdom": "^29.1.1",
    "knip": "^6.26.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wrangler": "^4.110.0"
  }
}
