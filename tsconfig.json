{
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "strict": true,
    "types": ["vite/client", "@cloudflare/workers-types"],
    "skipLibCheck": true
  },
  "include": ["src", "worker", "vite.config.ts", "vitest.config.ts"]
}
